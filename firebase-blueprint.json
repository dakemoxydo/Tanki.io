{
  "entities": {
    "UserStats": {
      "title": "UserStats",
      "description": "User statistics for the game",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "kills": { "type": "number" },
        "deaths": { "type": "number" },
        "matchesPlayed": { "type": "number" }
      },
      "required": ["uid", "displayName", "kills", "deaths", "matchesPlayed"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "UserStats" },
      "description": "User statistics"
    }
  }
}
